# ==============================================
# Solana Cross-DEX Arbitrage Bot — Configuration
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- REQUIRED ----

# Your Solana wallet private key (base58 encoded)
# This wallet needs SOL for gas and USDC for trading
# Export from Phantom: Settings > Security > Export Private Key
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Helius RPC endpoint (free tier: 1M credits/month)
# Sign up at https://helius.dev to get a free API key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# ---- OPTIONAL ----

# Telegram alerts (real-time notifications for opportunities and trades)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to true to scan without executing trades (safe testing mode)
DRY_RUN=false
