# ═══════════════════════════════════════════
#  Base Flash Loan Arbitrage Bot — .env
# ═══════════════════════════════════════════

# Your wallet private key (needs ETH on Base for gas)
PRIVATE_KEY=your_private_key_here

# Deployed ArbBot contract address (auto-filled by: npm run deploy)
CONTRACT_ADDRESS=

# Alchemy Base endpoints (get free keys at alchemy.com)
BASE_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set true to scan without executing real trades (safe testing)
DRY_RUN=true
